datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Order {
  id               String      @id @default(uuid())
  orderNumber      Int         @unique @default(autoincrement()) @map("order_number")
  orderTitle       String      @map("order_title")
  dateReceived     DateTime    @map("date_received")
  overallCondition String      @map("overall_condition")
  status           String
  notes            String?
  encodedBy        String?     @map("encoded_by")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  items            OrderItem[]

  @@map("orders")
}

model OrderItem {
  id                String                 @id @default(uuid())
  orderId           String                 @map("order_id")
  itemName          String                 @map("item_name")
  category          String?
  itemType          String                 @map("item_type") // CONSUMABLE or REUSABLE
  quantityReceived  Int                    @map("quantity_received")
  quantityUsed      Int                    @default(0) @map("quantity_used")
  quantityDeployed  Int                    @default(0) @map("quantity_deployed")
  quantityReturned  Int                    @default(0) @map("quantity_returned")
  availableQuantity Int                    @default(0) @map("available_quantity")
  currentStatus     String                 @map("current_status")
  notes             String?
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")
  order             Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  transactionItems  UsageTransactionItem[]

  @@map("order_items")
}

model UsageTransaction {
  id                 String                 @id @default(uuid())
  usageDate          DateTime               @map("usage_date")
  usageType          String                 @map("usage_type") // EVENT, OFFICE, or EMPLOYEE_REPLACEMENT
  eventName          String?                @map("event_name")
  venue              String?                @map("venue")
  officeUseDetails   String?                @map("office_use_details")
  employeeName       String?                @map("employee_name")
  employeeDepartment String?                @map("employee_department")
  reason             String?                @map("reason")
  encodedBy          String                 @map("encoded_by")
  notes              String?
  status             String                 @default("ACTIVE") // ACTIVE or VOIDED
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")
  items              UsageTransactionItem[]

  @@map("usage_transactions")
}

model UsageTransactionItem {
  id                 String           @id @default(uuid())
  usageTransactionId String           @map("usage_transaction_id")
  orderItemId        String           @map("order_item_id")
  quantity           Int
  itemNotes          String?          @map("item_notes")
  createdAt          DateTime         @default(now()) @map("created_at")
  usageTransaction   UsageTransaction @relation(fields: [usageTransactionId], references: [id], onDelete: Cascade)
  orderItem          OrderItem        @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@map("usage_transaction_items")
}

model AuditLog {
  id         String   @id @default(uuid())
  actionType String   @map("action_type")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  beforeData String   @map("before_data")
  afterData  String   @map("after_data")
  notes      String?
  timestamp  DateTime @default(now()) @map("timestamp")

  @@map("audit_logs")
}
